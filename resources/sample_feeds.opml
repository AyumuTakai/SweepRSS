<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>Sample RSS Feeds</title>
  </head>
  <body>

    <outline text="テクノロジー" title="テクノロジー">
      <outline type="rss" text="Hacker News" title="Hacker News" xmlUrl="https://news.ycombinator.com/rss"/>
      <outline type="rss" text="TechCrunch" title="TechCrunch" xmlUrl="https://techcrunch.com/feed/"/>
      <outline type="rss" text="The Verge" title="The Verge" xmlUrl="https://www.theverge.com/rss/index.xml"/>
      <outline type="rss" text="Wired" title="Wired" xmlUrl="https://www.wired.com/feed/rss"/>
      <outline type="rss" text="Ars Technica" title="Ars Technica" xmlUrl="https://feeds.arstechnica.com/arstechnica/index"/>
    </outline>

    <outline text="プログラミング" title="プログラミング">
      <outline type="rss" text="dev.to" title="dev.to" xmlUrl="https://dev.to/feed"/>
      <outline type="rss" text="Stack Overflow Blog" title="Stack Overflow Blog" xmlUrl="https://stackoverflow.blog/feed/"/>
      <outline type="rss" text="GitHub Blog" title="GitHub Blog" xmlUrl="https://github.blog/feed/"/>
      <outline type="rss" text="InfoQ" title="InfoQ" xmlUrl="https://feed.infoq.com/"/>
    </outline>

    <outline text="デザイン" title="デザイン">
      <outline type="rss" text="Smashing Magazine" title="Smashing Magazine" xmlUrl="https://www.smashingmagazine.com/feed/"/>
      <outline type="rss" text="CSS-Tricks" title="CSS-Tricks" xmlUrl="https://css-tricks.com/feed/"/>
      <outline type="rss" text="A List Apart" title="A List Apart" xmlUrl="https://alistapart.com/main/feed/"/>
    </outline>

    <outline text="ニュース" title="ニュース">
      <outline type="rss" text="Reuters Top News" title="Reuters Top News" xmlUrl="https://feeds.reuters.com/reuters/topNews"/>
      <outline type="rss" text="BBC World" title="BBC World" xmlUrl="https://feeds.bbci.co.uk/news/world/rss.xml"/>
      <outline type="rss" text="朝日新聞" title="朝日新聞" xmlUrl="https://www.asahi.com/rss/asahi/newsheadlines.rdf"/>
    </outline>

    <outline text="サイエンス" title="サイエンス">
      <outline type="rss" text="Nature News" title="Nature News" xmlUrl="https://www.nature.com/nature.rss"/>
      <outline type="rss" text="Scientific American" title="Scientific American" xmlUrl="https://rss.sciam.com/ScientificAmerican-Global"/>
      <outline type="rss" text="NASA Breaking News" title="NASA Breaking News" xmlUrl="https://www.nasa.gov/rss/dyn/breaking_news.rss"/>
    </outline>

  </body>
</opml>
